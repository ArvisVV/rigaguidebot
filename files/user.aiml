<?xml version="1.0" encoding="UTF-8"?>
<aiml version="2.0">

<category>
<pattern>SET NAME *</pattern>
<template>
Prieks iepazīties, <set name="name"><star/></set>!
</template>
</category>

<category>
<pattern>GET NAME</pattern>
<template>
Tavs vārds ir <get name="name"/>.
</template>
</category>

</aiml>